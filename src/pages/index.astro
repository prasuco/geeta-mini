---
import { getCollection } from "astro:content";
const chapters = await getCollection("chapters");
import BaseHead from "../base/BaseHead.astro";
import MobileLayout from "../base/layouts/MobileLayout.astro";
import ChapterItem from "../components/ChapterItem.astro";
import MailCTA from "../components/MailCTA.astro";

const sortedChapters = chapters.sort(
  (a, b) => a.data.chapter_number - b.data.chapter_number,
);

export const prerender = true;
---

<BaseHead
  title="Bhagavad Gita - Complete Chapters with Slok, Meaning & Commentary | Geeta.Prasuco.com"
  description={"Read the complete Bhagavad Gita online — all 18 chapters with original Sanskrit sloks, English and Nepali meanings, and chapter summaries. Experience the wisdom of Lord Krishna's teachings in a simple, modern way."}
>
  <MobileLayout>
    <!-- Hero Section -->
    <div class="relative overflow-hidden bg-white border-b border-gray-100 pb-12 pt-16 sm:pb-16 sm:pt-24 lg:pb-24 lg:pt-32 text-center">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-orange-50 via-white to-white opacity-70"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 mb-6 font-serif">
          The <span class="bg-clip-text text-transparent bg-gradient-to-r from-orange-500 to-orange-400">Bhagavad Gita</span>
        </h1>
        <p class="max-w-2xl mx-auto text-lg sm:text-xl text-gray-500 mb-10 leading-relaxed">
          Experience the timeless wisdom of Lord Krishna. 18 chapters, 700 verses, with original Sanskrit, detailed meanings, and diverse commentaries.
        </p>
        
        <!-- Search -->
        <div class="max-w-2xl mx-auto relative group">
          <input
            type="text"
            id="searchInput"
            placeholder="Search verses (e.g., 2.47) or keywords..."
            class="w-full px-6 py-4 pl-12 text-base md:text-lg bg-gray-50 border border-gray-200 rounded-2xl shadow-sm focus:bg-white focus:ring-2 focus:ring-orange-400 focus:border-orange-400 outline-none transition-all duration-300 placeholder:text-gray-400"
          />
          <svg
            class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-orange-500 transition-colors"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <div id="searchResults" class="hidden absolute w-full mt-2 bg-white border border-gray-100 rounded-xl shadow-xl max-h-80 overflow-y-auto z-50 text-left"></div>
        </div>
      </div>
    </div>

    <!-- Chapter Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900 font-serif">Chapters</h2>
        <span class="text-sm font-medium text-gray-500 bg-gray-100 px-3 py-1 rounded-full">All 18 Chapters</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedChapters.map((chapter) => <ChapterItem data={chapter} />)}
      </div>
    </div>

    <!-- CTA Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <MailCTA />
    </div>

  </MobileLayout>
</BaseHead>

<script>
  document.addEventListener("astro:page-load", () => {
    const searchInput = document.getElementById(
      "searchInput",
    ) as HTMLInputElement;
    const searchResults = document.getElementById("searchResults");
    let searchData: any[] | null = null;

    if (!searchInput || !searchResults) return;

    async function ensureSearchData() {
      if (searchData) return searchData;
      try {
        const response = await fetch('/search-index.json');
        searchData = await response.json();
        return searchData;
      } catch (err) {
        console.error('Failed to fetch search data', err);
        return [];
      }
    }

    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get("q") || urlParams.get("verse");

    if (q) {
      searchInput.value = q;
      ensureSearchData().then(data => {
        const results = performSearch(q, data || []);
        displayResults(results);
      });
    }

    searchInput?.addEventListener("input", async (e) => {
      const query = (e.target as HTMLInputElement).value;

      if (query.length < 1) {
        searchResults?.classList.add("hidden");
        return;
      }

      const data = await ensureSearchData();
      const results = performSearch(query, data || []);
      displayResults(results);
    });

    // ... existing performSearch and displayResults functions ...

    function performSearch(query: string, data: any[]) {
      const normalizedQuery = query.toLowerCase().trim();
      const verseMatch = normalizedQuery.match(/(\d+)\.?\s*(\d*)/);
      if (verseMatch) {
        const chapter = parseInt(verseMatch[1]);
        const verse = verseMatch[2] ? parseInt(verseMatch[2]) : null;
        if (verse) {
          const exact = data.filter(
            (d) => d.chapter === chapter && d.verse === verse,
          );
          if (exact.length) return exact;
        }
        if (!verse) {
          return data.filter((d) => d.chapter === chapter).slice(0, 5);
        }
      }
      return data
        .filter((d) => d.text.toLowerCase().includes(normalizedQuery))
        .slice(0, 5);
    }

    function displayResults(results: any[]) {
      if (!searchResults) return;
      if (results.length === 0) {
        searchResults.innerHTML =
          '<p class="p-2 text-xs text-gray-500">No verses found</p>';
        searchResults.classList.remove("hidden");
        return;
      }
      searchResults.innerHTML = results
        .map(
          (r) => `
        <a href="/${r.chapter}/${r.verse}" class="block px-3 py-2 hover:bg-orange-50 border-b last:border-b-0">
          <span class="font-medium text-sm">${r.chapter}.${r.verse}</span>
          <span class="text-xs text-gray-500 ml-2">${r.text.substring(0, 40)}...</span>
        </a>
      `,
        )
        .join("");
      searchResults.classList.remove("hidden");
    }

    document.addEventListener("click", (e) => {
      if (
        !searchInput.contains(e.target as Node) &&
        !searchResults?.contains(e.target as Node)
      ) {
        searchResults?.classList.add("hidden");
      }
    });
  });
</script>
