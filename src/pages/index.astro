---
import { getCollection } from "astro:content";
const chapters = await getCollection("chapters");
const sloks = await getCollection("sloks");
import BaseHead from "../base/BaseHead.astro";
import MobileLayout from "../base/layouts/MobileLayout.astro";
import ChapterItem from "../components/ChapterItem.astro";

const sortedChapters = chapters.sort(
  (a, b) => a.data.chapter_number - b.data.chapter_number,
);

export const prerender = false;
---

<BaseHead
  title="Bhagavad Gita - Complete Chapters with Slok, Meaning & Commentary | Geeta.Prasuco.com"
  description={"Read the complete Bhagavad Gita online — all 18 chapters with original Sanskrit sloks, English and Nepali meanings, and chapter summaries. Experience the wisdom of Lord Krishna's teachings in a simple, modern way."}
>
  <MobileLayout>
    <!-- Search -->
    <div class="px-4 py-3">
      <div class="relative">
        <input
          type="text"
          id="searchInput"
          placeholder="Search verse (e.g., 2.47)"
          class="w-full px-3 py-2 pl-9 text-sm border border-gray-200 rounded-lg focus:ring-1 focus:ring-orange-400 focus:border-orange-400 outline-none bg-gray-50"
        />
        <svg
          class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <div
        id="searchResults"
        class="hidden mt-1 bg-white border rounded-lg shadow-sm max-h-48 overflow-y-auto"
      >
      </div>
    </div>

    <div class="divide-y divide-gray-100">
      {sortedChapters.map((chapter) => <ChapterItem data={chapter} />)}
    </div>

    <!-- Search data for client-side search -->
    <script
      type="application/json"
      id="searchData"
      set:html={JSON.stringify(
        sloks.map((s) => ({
          chapter: s.data.chapter_number,
          verse: s.data.verse_number,
          text: s.data.text,
          id: s.id,
        })),
      )}
    />
  </MobileLayout>
</BaseHead>

<script>
  document.addEventListener("astro:page-load", () => {
    const searchInput = document.getElementById(
      "searchInput",
    ) as HTMLInputElement;
    const searchResults = document.getElementById("searchResults");
    const searchData = JSON.parse(
      document.getElementById("searchData")?.textContent || "[]",
    );

    if (!searchInput || !searchResults) return;

    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get("q") || urlParams.get("verse");

    if (q) {
      searchInput.value = q;
      const results = performSearch(q, searchData);
      displayResults(results);
    }

    searchInput?.addEventListener("input", (e) => {
      const query = (e.target as HTMLInputElement).value;

      if (query.length < 1) {
        searchResults?.classList.add("hidden");
        return;
      }

      const results = performSearch(query, searchData);
      displayResults(results);
    });

    function performSearch(query: string, data: any[]) {
      const normalizedQuery = query.toLowerCase().trim();
      const verseMatch = normalizedQuery.match(/(\d+)\.?\s*(\d*)/);
      if (verseMatch) {
        const chapter = parseInt(verseMatch[1]);
        const verse = verseMatch[2] ? parseInt(verseMatch[2]) : null;
        if (verse) {
          const exact = data.filter(
            (d) => d.chapter === chapter && d.verse === verse,
          );
          if (exact.length) return exact;
        }
        if (!verse) {
          return data.filter((d) => d.chapter === chapter).slice(0, 5);
        }
      }
      return data
        .filter((d) => d.text.toLowerCase().includes(normalizedQuery))
        .slice(0, 5);
    }

    function displayResults(results: any[]) {
      if (!searchResults) return;
      if (results.length === 0) {
        searchResults.innerHTML =
          '<p class="p-2 text-xs text-gray-500">No verses found</p>';
        searchResults.classList.remove("hidden");
        return;
      }
      searchResults.innerHTML = results
        .map(
          (r) => `
        <a href="/${r.chapter}/${r.verse}" class="block px-3 py-2 hover:bg-orange-50 border-b last:border-b-0">
          <span class="font-medium text-sm">${r.chapter}.${r.verse}</span>
          <span class="text-xs text-gray-500 ml-2">${r.text.substring(0, 40)}...</span>
        </a>
      `,
        )
        .join("");
      searchResults.classList.remove("hidden");
    }

    document.addEventListener("click", (e) => {
      if (
        !searchInput.contains(e.target as Node) &&
        !searchResults?.contains(e.target as Node)
      ) {
        searchResults?.classList.add("hidden");
      }
    });
  });
</script>
