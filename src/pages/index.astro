---
import { getCollection } from "astro:content";
const chapters = await getCollection("chapters");
const sloks = await getCollection("sloks");
import BaseHead from "../base/BaseHead.astro";
import MobileLayout from "../base/layouts/MobileLayout.astro";
import ChapterItem from "../components/ChapterItem.astro";

const sortedChapters = chapters.sort(
  (a, b) => a.data.chapter_number - b.data.chapter_number,
);

// Get verse of the day based on date
const today = new Date();
const dayOfYear = Math.floor(
  (today.getTime() - new Date(today.getFullYear(), 0, 0).getTime()) /
    (1000 * 60 * 60 * 24),
);
const verseOfTheDayIndex = dayOfYear % sloks.length;
const verseOfTheDay = sloks[verseOfTheDayIndex];

export const prerender = false;
---

<BaseHead
  title="Bhagavad Gita - Complete Chapters with Slok, Meaning & Commentary | Geeta.Prasuco.com"
  description={"Read the complete Bhagavad Gita online — all 18 chapters with original Sanskrit sloks, English and Nepali meanings, and chapter summaries. Experience the wisdom of Lord Krishna's teachings in a simple, modern way."}
>
  <MobileLayout>
    <!-- Search -->
    <div class="p-4">
      <div class="relative">
        <input
          type="text"
          id="searchInput"
          placeholder="Search verse (e.g., 2.47) or keyword..."
          class="w-full px-4 py-3 pl-10 border rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none"
        />
        <svg
          class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <div
        id="searchResults"
        class="hidden mt-2 bg-white border rounded-lg shadow-lg max-h-64 overflow-y-auto"
      >
      </div>
    </div>

    <!-- Verse of the Day -->
    <div
      class="mx-4 mb-4 p-4 bg-linear-to-r from-orange-50 to-amber-50 border border-orange-200 rounded-lg"
    >
      <div class="flex items-center gap-2 mb-2">
        <span class="text-orange-500">✨</span>
        <h3 class="font-semibold text-orange-800">Verse of the Day</h3>
      </div>
      <a
        href={`/${verseOfTheDay.data.chapter_number}/${verseOfTheDay.data.verse_number}`}
        class="block"
      >
        <p class="text-xl font-medium text-sanskrit mb-1">
          {verseOfTheDay.data.chapter_number}.{verseOfTheDay.data.verse_number}
        </p>
        <p class="text-sm text-gray-600 line-clamp-2">
          {verseOfTheDay.data.text.substring(0, 100)}...
        </p>
        <span class="inline-block mt-2 text-sm text-orange-600 font-medium"
          >Read now →</span
        >
      </a>
    </div>

    <!-- Geeta in Mail CTA -->
    <div class="mx-4 mb-4 p-4 bg-orange-500 rounded-lg text-white text-center">
      <p class="font-medium mb-2">Get daily verses in your inbox</p>
      <a
        href="/geeta-mail"
        class="inline-block px-4 py-2 bg-white text-orange-600 text-sm font-medium rounded hover:bg-gray-100 transition"
      >
        Subscribe Free
      </a>
    </div>

    <div class="m-2 gap-2 flex flex-col">
      {sortedChapters.map((chapter) => <ChapterItem data={chapter} />)}
    </div>

    <!-- Search data for client-side search -->
    <script
      type="application/json"
      id="searchData"
      set:html={JSON.stringify(
        sloks.map((s) => ({
          chapter: s.data.chapter_number,
          verse: s.data.verse_number,
          text: s.data.text,
          id: s.id,
        })),
      )}
    />
  </MobileLayout>
</BaseHead>

<script>
  document.addEventListener("astro:page-load", () => {
    const searchInput = document.getElementById(
      "searchInput",
    ) as HTMLInputElement;
    const searchResults = document.getElementById("searchResults");
    const searchData = JSON.parse(
      document.getElementById("searchData")?.textContent || "[]",
    );

    if (!searchInput || !searchResults) return;

    // Check for verse lookup (e.g., ?q=2.47 or ?verse=2.47)
    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get("q") || urlParams.get("verse");

    if (q) {
      searchInput.value = q;
      // Trigger search
      const results = performSearch(q, searchData);
      displayResults(results);
    }

    searchInput?.addEventListener("input", (e) => {
      const query = (e.target as HTMLInputElement).value;

      if (query.length < 2) {
        searchResults?.classList.add("hidden");
        return;
      }

      const results = performSearch(query, searchData);
      displayResults(results);
    });

    function performSearch(query: string, data: any[]) {
      const normalizedQuery = query.toLowerCase().trim();

      // Check if it's a verse number (e.g., "2.47" or "2 47" or "chapter 2 verse 47")
      const verseMatch = normalizedQuery.match(/(\d+)\.?\s*(\d*)/);
      if (verseMatch) {
        const chapter = parseInt(verseMatch[1]);
        const verse = verseMatch[2] ? parseInt(verseMatch[2]) : null;

        if (verse) {
          const exact = data.filter(
            (d) => d.chapter === chapter && d.verse === verse,
          );
          if (exact.length) return exact;
        }

        // If only chapter specified, show all verses in chapter
        if (!verse) {
          return data.filter((d) => d.chapter === chapter).slice(0, 10);
        }
      }

      // Text search in Sanskrit
      return data
        .filter((d) => d.text.toLowerCase().includes(normalizedQuery))
        .slice(0, 10);
    }

    function displayResults(results: any[]) {
      if (!searchResults) return;

      if (results.length === 0) {
        searchResults.innerHTML =
          '<p class="p-3 text-sm text-gray-500">No verses found</p>';
        searchResults.classList.remove("hidden");
        return;
      }

      searchResults.innerHTML = results
        .map(
          (r) => `
        <a href="/${r.chapter}/${r.verse}" class="block p-3 hover:bg-orange-50 border-b last:border-b-0">
          <p class="font-medium">Chapter ${r.chapter}, Verse ${r.verse}</p>
          <p class="text-sm text-gray-600 truncate">${r.text.substring(0, 60)}...</p>
        </a>
      `,
        )
        .join("");
      searchResults.classList.remove("hidden");
    }

    // Close search when clicking outside
    document.addEventListener("click", (e) => {
      if (
        !searchInput.contains(e.target as Node) &&
        !searchResults?.contains(e.target as Node)
      ) {
        searchResults?.classList.add("hidden");
      }
    });
  });
</script>
