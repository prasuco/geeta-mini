---
import type { CollectionEntry } from "astro:content";

type Props = {
  data: CollectionEntry<"chapters">;
};

const { data } = Astro.props;
export const prerender = true;
---

<a
  transition:name={`chapter-name-${data.data.chapter_number}`}
  href={`/${data.id}`}
  class="block px-4 py-3 hover:bg-gray-50 transition-colors"
>
  <div class="flex items-center gap-3">
    <span class="text-orange-600 font-semibold">{data.data.chapter_number}</span>
    <div class="flex-1 min-w-0">
      <p class="font-medium text-gray-900 truncate">{data.data.name_meaning}</p>
      <p class="text-xs text-gray-500">{data.data.name}</p>
    </div>
  </div>
</a>
