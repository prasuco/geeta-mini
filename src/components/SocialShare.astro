---
import { Share2 } from "@lucide/astro";

const url = Astro.request.url;
export const prerender = true;
---

<!-- jq and modal from public -->
<script is:inline src="/js/jquery.min.js"></script>
<link rel="stylesheet" href="/css/jquery.modal.css" />
<script is:inline src="/js/jquery.modal.js"></script>

<div>
  <!-- Share Button -->
  <a
    title="Share The Slok"
    id="openModal"
    href="#shareModal"
    rel="modal:open"
    class="fixed bottom-30 right-5 p-3 rounded-full bg-orange-500 hover:bg-orange-600 active:bg-orange text-white text-sm font-semibold shadow-md transition"
  >
    <Share2 />
  </a>

  <!-- Modal -->
  <div id="shareModal" class="modal">
    <div class="">
      <!-- Header -->
      <div class="flex items-center justify-between pb-3 mb-4">
        <h3 class="text-lg font-semibold text-slate-800">Share this slok</h3>
      </div>

      <!-- Social -->
      <div class="text-center">
        <p class="text-sm font-medium text-slate-700 mb-3">Share via</p>

        <div class="flex gap-4 justify-center">
          <button
            id="shareFb"
            class="w-10 h-10 rounded-full bg-blue-600 hover:bg-blue-700 text-white flex items-center justify-center font-bold"
          >
            f
          </button>

          <button
            id="shareX"
            class="w-10 h-10 rounded-full bg-black hover:bg-gray-800 text-white flex items-center justify-center font-bold"
          >
            X
          </button>

          <button
            id="shareLinkedin"
            class="w-10 h-10 rounded-full bg-[#0077b5] hover:bg-[#005e94] text-white flex items-center justify-center font-bold"
          >
            in
          </button>
        </div>
      </div>

      <!-- Copy -->
      <div class="mt-8">
        <p class="text-sm font-medium text-slate-700 mb-2">Or copy link</p>

        <div class="flex border rounded-lg overflow-hidden">
          <input
            id="shareUrl"
            value={url}
            readonly
            class="flex-1 px-3 py-2 text-sm text-slate-600 outline-none"
          />
          <button
            id="copyBtn"
            class="px-4 bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium transition"
          >
            Copy
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script lang="ts">
  function initShareModal() {
    const openBtn = document.getElementById("openModal");
    const shareUrlInput = document.getElementById("shareUrl");
    const copyBtn = document.getElementById("copyBtn");

    const shareFb = document.getElementById("shareFb");
    const shareX = document.getElementById("shareX");
    const shareLinkedin = document.getElementById("shareLinkedin");

    if (!openBtn || !shareUrlInput) return;

    const currentUrl = shareUrlInput.value;

    shareFb?.addEventListener("click", () => {
      window.open(
        `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`,
        "_blank",
      );
    });

    shareX?.addEventListener("click", () => {
      window.open(
        `https://twitter.com/intent/tweet?url=${encodeURIComponent(currentUrl)}`,
        "_blank",
      );
    });

    shareLinkedin?.addEventListener("click", () => {
      window.open(
        `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`,
        "_blank",
      );
    });

    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(currentUrl);
        copyBtn.textContent = "Copied!";
        setTimeout(() => {
          if (copyBtn) copyBtn.textContent = "Copy";
        }, 2000);
      } catch {
        alert("Copy failed.");
      }
    });
  }

  initShareModal();
  document.addEventListener("astro:page-load", initShareModal);
</script>
