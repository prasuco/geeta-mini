<div class="p-6 space-y-8">
  <div class="flex items-center justify-between border-b pb-4">
    <h2 class="text-lg font-bold">Customize Post</h2>
    <a href="javascript:history.back()" class="text-sm text-gray-400 hover:text-gray-900 transition-colors">Close</a>
  </div>

  <!-- Format Selection -->
  <div class="space-y-3">
    <label class="block text-xs font-bold uppercase tracking-wider text-gray-400">Layout Format</label>
    <div class="grid grid-cols-2 gap-2">
      <button data-format="square" class="format-btn p-3 border-2 border-orange-600 bg-orange-50 rounded-xl text-center transition-all">
        <span class="block text-sm font-bold">Square</span>
        <span class="text-[10px] text-gray-500">1:1 (Facebook Post)</span>
      </button>
      <button data-format="story" class="format-btn p-3 border-2 border-gray-100 rounded-xl text-center transition-all hover:border-orange-200">
        <span class="block text-sm font-bold">Story</span>
        <span class="text-[10px] text-gray-500">9:16 (Facebook Story)</span>
      </button>
    </div>
  </div>

  <!-- Design Presets -->
  <div class="space-y-3">
    <label class="block text-xs font-bold uppercase tracking-wider text-gray-400">Design Preset</label>
    <div class="grid grid-cols-4 gap-2">
      <button data-theme="light" class="theme-btn w-full aspect-square rounded-lg border-2 border-orange-600 bg-white shadow-sm ring-2 ring-orange-50 transition-all"></button>
      <button data-theme="dark" class="theme-btn w-full aspect-square rounded-lg border-2 border-transparent bg-gray-900 hover:border-orange-300 transition-all"></button>
      <button data-theme="saffron" class="theme-btn w-full aspect-square rounded-lg border-2 border-transparent bg-orange-500 hover:border-orange-300 transition-all"></button>
      <button data-theme="minimal" class="theme-btn w-full aspect-square rounded-lg border-2 border-transparent bg-gray-50 hover:border-orange-300 transition-all"></button>
    </div>
  </div>

  <!-- Custom Text Controls -->
  <div class="space-y-6 pt-4 border-t border-gray-100">
    <div class="space-y-3">
      <label class="block text-xs font-bold uppercase tracking-wider text-gray-400">Sanskrit Font Size</label>
      <input type="range" id="sanskritSize" min="16" max="48" value="28" class="w-full accent-orange-600" />
    </div>

    <div class="space-y-3">
      <label class="block text-xs font-bold uppercase tracking-wider text-gray-400">Translation Font Size</label>
      <input type="range" id="translationSize" min="14" max="32" value="18" class="w-full accent-orange-600" />
    </div>
  </div>

  <!-- Download Action -->
  <div class="pt-6">
    <button id="downloadBtn" class="w-full py-4 bg-gray-900 text-white rounded-2xl font-bold shadow-xl shadow-gray-200 hover:bg-orange-600 hover:-translate-y-1 active:scale-95 transition-all flex items-center justify-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      Export Verse Image
    </button>
    <p class="text-center text-[10px] text-gray-400 mt-3">High quality 1440px PNG for best social clarity.</p>
  </div>
</div>

<script>
  // Script logic will be handled centrally in the page or Canvas component
</script>
