---
import { ClientRouter } from "astro:transitions";
import "../styles/globals.css";

type Props = {
  title: string;
  description?: string;
  chapter?: number;
  verse?: number;
};

// import "@fontsource-variable/inter";

const {
  description = "Bhagavad Gita |  Complete Chapters with Slok, Meaning & Commentary | Geeta.Prasuco.com",
  title,
  chapter,
  verse,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = chapter && verse 
  ? `/og/${chapter}/${verse}.webp`
  : chapter 
    ? `/og/${chapter}.webp`
    : `/og.png`;

const schema = chapter && verse ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `Bhagavad Gita Chapter ${chapter}, Verse ${verse}`,
  "description": description,
  "image": ogImage,
  "url": canonicalURL.href,
  "author": {
    "@type": "Person",
    "name": "Krishna"
  },
  "book": {
    "@type": "Book",
    "name": "Bhagavad Gita",
    "author": {
      "@type": "Person",
      "name": "Vyasa"
    }
  }
} : chapter ? {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "headline": `Bhagavad Gita Chapter ${chapter}`,
  "description": description,
  "image": ogImage,
  "url": canonicalURL.href
} : {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Geeta Mini - Bhagavad Gita",
  "description": description,
  "url": canonicalURL.href,
  "potentialAction": {
    "@type": "SearchAction",
    "target": "/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <style>
      * {
        font-family: "Inter Variable", sans-serif;
      }
    </style>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Open Graph -->
    <meta property="og:type" content={chapter && verse ? "article" : chapter ? "website" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL.href} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    {
      process.env.NODE_ENV === "production" && (
        <script
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id="e13deb2e-6518-4468-9ac9-dc048737504e"
        />
      )
    }

    <!-- jQuery and jQuery Modal -->
    <script is:inline src="/js/jquery.min.js"></script>
    <script is:inline src="/js/jquery.modal.js"></script>
    <link rel="stylesheet" href="/css/jquery.modal.css" />

    <ClientRouter />
  </head>
  <body data-umami-auto-track data-umami-auto-track-all-clicks="true">
    <slot />
  </body>
</html>
